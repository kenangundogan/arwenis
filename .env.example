# MongoDB baglanti URL'i. Lokal: mongodb://127.0.0.1/arwenis
DATABASE_URL=mongodb://127.0.0.1/arwenis

# Payload CMS'in JWT/cookie imzalama secret'i.
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Scheduled publish + Payload jobs cron endpoint'lerini koruyan secret. /api/payload-jobs/run?secret=... formatinda kullanilir.
CRON_SECRET=YOUR_CRON_SECRET

# Draft preview URL'lerini imzalamak icin kullanilan secret. Yayinlanmamis icerigi onizlemek icin.
PREVIEW_SECRET=YOUR_PREVIEW_SECRET

# S3 (Garage / AWS S3 uyumlu)
# S3 API endpoint'i. Garage/MinIO/AWS uyumlu obje deposu adresi.
S3_ENDPOINT_URL=https://your-s3-endpoint.example.com

# Public bucket CNAME. Yuklenen dosyalarin frontend'e donen URL prefix'i (CDN-friendly).
S3_PUBLIC_URL=https://your-public-bucket-cname.example.com

# S3 region. AWS icin 'us-east-1' vb., Garage icin custom isim.
S3_REGION=your-region

# Dosyalarin yuklenecegi bucket adi.
S3_BUCKET=your-bucket-name

# S3 access key ID. Bucket'a yazma yetkisi olan IAM kullanicisi/keyi.
S3_ACCESS_KEY_ID=YOUR_S3_ACCESS_KEY

# S3 secret access key (gizli). Hicbir zaman client-side koda dahil edilmemeli.
S3_SECRET_ACCESS_KEY=YOUR_S3_SECRET_KEY
